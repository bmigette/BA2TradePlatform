# Frontend environment config (Vite). Copy to .env.local and adjust as needed.
# .env.local is gitignored; this .env.example is the documented template.

# Backend API base URL. When unset, the app defaults to http://localhost:8000/api
# (see src/lib/config.ts). Set this if your backend runs on a different host/port,
# e.g. when :8000 is taken:
# VITE_API_BASE=http://localhost:8001/api
